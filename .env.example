# 라이트닝 지갑 연동 (트랙 B — 목표 달성 자동 판정용)
# 이 파일을 .env 로 복사해 채우세요. (.env는 gitignore됨)

# ── Blink (기본 선택지) ──
# Blink 앱 설치 후 dashboard.blink.sv 에서 API 키 발급 (Read 스코프면 충분)
BLINK_API_KEY=
# 기본 엔드포인트 사용 시 비워두면 됨 (https://api.blink.sv/graphql)
BLINK_ENDPOINT=

# ── LNbits (대안 — BLINK_API_KEY가 없을 때만 사용됨) ──
LNBITS_URL=
LNBITS_READ_KEY=
